# Copy to .env for local `npm run dev`. Not used by Docker/Render builds —
# those get these values injected at container startup instead (see
# frontend/40-generate-runtime-config.sh and the README's Auth section).

# Optional — only needed to test login/register locally. Same values as
# backend/.env's SUPABASE_URL / SUPABASE_PUBLISHABLE_KEY.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
