# Copy this file to .env and fill in your values

OPENAI_API_KEY=sk-your-key-here

# --- Database ---
# Leave as-is to use local SQLite (zero setup). To use Supabase Postgres:
# Supabase dashboard -> Project Settings -> Database -> Connection string
# -> URI (use the "Transaction pooler" string, port 6543, for serverless-
# friendly pooled connections). It looks like:
#   postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./data/app.db

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Supabase Auth ---
# Project Settings -> API. Use the project URL and the "publishable" key
# (sb_publishable_...) — NOT the legacy anon key (Supabase is deprecating
# legacy keys by end of 2026) and NOT the secret key (never put that in a
# frontend-facing config; the backend only verifies tokens, it doesn't
# need the secret key either).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
